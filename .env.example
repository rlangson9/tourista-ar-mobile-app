# Copy this file to .env and fill in your real keys.
# NEVER commit .env to git — it is already in .gitignore.

# AI provider (DeepSeek or swap for another OpenAI-compatible API)
VITE_AI_API_KEY=your_api_key_here
VITE_AI_BASE_URL=https://api.deepseek.com/v1

# App config
VITE_APP_NAME=Tourista AR
VITE_REGISTRATION_PORTAL_URL=https://tourista-ar.com/register
VITE_API_URL=http://localhost:5002
